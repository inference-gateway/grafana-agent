# Gateway
ANTHROPIC_API_KEY=
CLOUDFLARE_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=
OLLAMA_API_KEY=
OLLAMA_CLOUD_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=

# A2A Agent Server / LLM client
A2A_DEBUG=false
A2A_AGENT_CLIENT_PROVIDER=
A2A_AGENT_CLIENT_MODEL=
A2A_AGENT_CLIENT_BASE_URL=http://gateway:8080/v1

# CLI
CLI_PROVIDER=
CLI_MODEL=

# OpenTelemetry (spec.telemetry.enabled: true)
# A2A_TELEMETRY_ENABLE is the ADK master switch: it turns on instrumentation and
# the telemetry server. The A2A_OTEL_* variables are the standard OpenTelemetry
# SDK settings read through the ADK's A2A_-prefixed config, so each OTEL_* name is
# emitted with the A2A_ prefix; every one maps 1:1 to a spec.telemetry field. A
# signal set to "none" is disabled; drop an OTLP endpoint/protocol to fall back to
# the SDK default. Auth headers, credentials, and sampling stay runtime concerns.
# W3C trace-context + baggage propagation is automatic.
A2A_TELEMETRY_ENABLE=true
A2A_OTEL_TRACES_EXPORTER=none
A2A_OTEL_METRICS_EXPORTER=prometheus
A2A_OTEL_EXPORTER_PROMETHEUS_PORT=9464
